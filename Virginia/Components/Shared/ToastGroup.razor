@* Behavior in ToastGroup.razor.cs *@

@if (Toasts.Toasts.Count > 0)
{
    <div class="toast-stack" data-testid="toast-stack">
        @foreach (var toast in Toasts.Toasts)
        {
            <div class="toast toast-@toast.SeverityClass"
                 role="@RoleFor(toast.Severity)"
                 aria-live="@LiveFor(toast.Severity)"
                 aria-atomic="true"
                 data-testid="toast"
                 data-toast-severity="@toast.SeverityClass"
                 @key="toast.Id">
                <span class="sr-only">@toast.SeverityLabel:</span>
                <span class="toast-text">@toast.Message</span>
                @if (toast.OnReload is not null)
                {
                    <button type="button"
                            class="toast-action"
                            data-testid="toast-reload"
                            @onclick="() => InvokeReload(toast)">
                        Reload
                    </button>
                }
                <button type="button"
                        class="toast-dismiss"
                        aria-label="Dismiss @toast.SeverityLabel"
                        data-testid="toast-dismiss"
                        @onclick="() => Toasts.Dismiss(toast.Id)">
                    ✕
                </button>
            </div>
        }
    </div>
}
