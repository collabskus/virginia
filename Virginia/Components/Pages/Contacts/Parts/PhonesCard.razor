@using Virginia.Data

<section class="card" aria-labelledby="phones-heading">
    <div class="card-head">
        <h2 id="phones-heading">Phones</h2>
        <button type="button"
                class="btn btn-add"
                data-testid="add-phone"
                @onclick="AddPhone">
            + Add phone
        </button>
    </div>

    @if (Items.Count == 0)
    {
        <p class="hint" data-testid="phones-empty">No phone numbers yet.</p>
    }
    else
    {
        <ul class="child-list" role="list" data-testid="phones-list">
            @foreach (var item in Items)
            {
                var labelId = $"phone-label-{item.GetHashCode():x}";
                var numId = $"phone-num-{item.GetHashCode():x}";
                var valId = $"phone-val-{item.GetHashCode():x}";
                <li class="child-item" @key="item" data-testid="phone-item">
                    <div class="row">
                        <div class="group group-sm">
                            <label for="@labelId">Label</label>
                            <InputText id="@labelId"
                                       @bind-Value="item.Label"
                                       data-testid="phone-label" />
                        </div>
                        <div class="group">
                            <label for="@numId">
                                Number <span aria-hidden="true">*</span>
                            </label>
                            <InputText id="@numId"
                                       @bind-Value="item.Number"
                                       type="tel"
                                       aria-required="true"
                                       aria-describedby="@valId"
                                       data-testid="phone-number" />
                            <div id="@valId" class="field-validation">
                                <ValidationMessage For="() => item.Number" />
                            </div>
                        </div>
                        <button type="button"
                                class="btn-x"
                                aria-label="Remove phone"
                                data-testid="remove-phone"
                                @onclick="() => RemovePhone(item)">
                            ✕
                        </button>
                    </div>
                </li>
            }
        </ul>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public List<PhoneFormModel> Items { get; set; } = default!;

    private void AddPhone() => Items.Add(new PhoneFormModel());
    private void RemovePhone(PhoneFormModel item) => Items.Remove(item);
}
