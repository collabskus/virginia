@* Behavior in NotesCard.razor.cs *@
@using Virginia.Data

<section class="card" aria-labelledby="notes-heading">
    <div class="card-head">
        <h2 id="notes-heading">Notes</h2>
    </div>

    <div class="note-input">
        <label for="new-note" class="sr-only">New note</label>
        <textarea id="new-note"
                  @bind="NewNoteContent"
                  placeholder="Add a note..."
                  rows="3"
                  class="note-textarea"
                  data-testid="new-note-input"
                  disabled="@Submitting"></textarea>
        <button type="button"
                class="btn btn-add"
                data-testid="save-note"
                disabled="@(Submitting || string.IsNullOrWhiteSpace(NewNoteContent))"
                @onclick="OnSaveNoteAsync">
            @(Submitting ? "Saving..." : "Save Note")
        </button>
    </div>

    @if (Detail.Notes.Count == 0)
    {
        <p class="hint" data-testid="notes-empty">No notes yet.</p>
    }
    else
    {
        <ol class="notes-list" data-testid="notes-list">
            @foreach (var note in Detail.Notes)
            {
                <li class="note-item" @key="note.Id" data-testid="note-item">
                    <div class="note-meta">
                        <strong data-testid="note-author">@note.CreatedByUserName</strong>
                        <time class="note-date"
                              datetime="@note.CreatedAtUtc.ToString("O")"
                              data-testid="note-date">
                            @note.CreatedAtUtc.ToString("MMM d, yyyy h:mm tt") UTC
                        </time>
                    </div>
                    <div class="note-content" data-testid="note-content">@note.Content</div>
                </li>
            }
        </ol>
    }
</section>
