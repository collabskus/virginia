@page "/admin/users"
@using Virginia.Components.Common
@using Virginia.Data
@attribute [Authorize(Roles = "Admin")]
@rendermode InteractiveServer
@inject IUserAdminService UserAdmin
@inject ILogger<UserManagement> Logger
@implements IDisposable

<PageTitle>User Management | Virginia</PageTitle>

<div class="page">
    <div class="page-header">
        <h1>User Management</h1>
    </div>

    @if (error is not null)
    {
        <div class="banner banner-error" role="alert">@error</div>
    }

    @if (success is not null)
    {
        <div class="banner banner-success" role="status">@success</div>
    }

    <!-- Filters: email search + status. Server-side, so a user on any page
         is reachable by typing their email — the test relies on this. -->
    <div class="user-filters">
        <div class="user-field">
            <label for="fEmail">Email</label>
            <input id="fEmail" type="text" placeholder="Search by email..."
                   data-testid="user-filter-email"
                   @bind="filterEmail" @bind:event="oninput"
                   @bind:after="OnFilterChanged" />
        </div>
        <div class="user-field">
            <label for="fStatus">Status</label>
            <select id="fStatus" data-testid="user-filter-status"
                    @bind="filterStatus" @bind:after="OnFilterChanged">
                <option value="">Any</option>
                <option value="pending">Pending</option>
                <option value="approved">Approved</option>
            </select>
        </div>
        <button class="btn btn-text" @onclick="ClearFilters">Clear filters</button>
    </div>

    @if (result is null)
    {
        <div class="status" aria-live="polite">Loading users...</div>
    }
    else if (result.TotalCount == 0)
    {
        <div class="status" aria-live="polite" data-testid="users-empty">
            No users found.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Approved</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in result.Items)
                    {
                        <tr @key="u.Id">
                            <td>@u.Email</td>
                            <td>@u.Role</td>
                            <td>
                                @if (u.IsApproved)
                                {
                                    <span class="badge badge-ok">Approved</span>
                                }
                                else
                                {
                                    <span class="badge badge-pending">Pending</span>
                                }
                            </td>
                            <td>@u.CreatedAtUtc.ToString("yyyy-MM-dd")</td>
                            <td class="actions-cell">
                                @if (!u.IsApproved)
                                {
                                    <button class="btn btn-sm btn-approve"
                                            disabled="@(busyId == u.Id)"
                                            @onclick="() => ApproveAsync(u.Id)">Approve</button>
                                }
                                else if (u.Role != "Admin")
                                {
                                    <button class="btn btn-sm btn-revoke"
                                            disabled="@(busyId == u.Id)"
                                            @onclick="() => RevokeAsync(u.Id)">Revoke</button>
                                }

                                @if (u.Role != "Admin")
                                {
                                    <button class="btn btn-sm btn-promote"
                                            disabled="@(busyId == u.Id)"
                                            @onclick="() => PromoteAsync(u.Id)">Make Admin</button>
                                }

                                @if (u.Role != "Admin")
                                {
                                    <button class="btn btn-sm btn-delete"
                                            disabled="@(busyId == u.Id)"
                                            @onclick="() => DeleteAsync(u.Id)">Delete</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <nav class="pager" aria-label="Pagination">
            <button class="btn btn-sm" data-testid="users-prev"
                    disabled="@(!result.HasPrevious)" @onclick="PrevPage">
                ← Prev
            </button>
            <span class="pager-info" data-testid="users-page-info">
                Page @result.Page of @result.TotalPages
                <span class="hide-sm">(@result.TotalCount users)</span>
            </span>
            <button class="btn btn-sm" data-testid="users-next"
                    disabled="@(!result.HasNext)" @onclick="NextPage">
                Next →
            </button>
        </nav>
    }
</div>

@code {
    private PagedResult<UserAdminRow>? result;
    private string? error;
    private string? success;
    private string? busyId;

    private int page = 1;

    private string filterEmail = "";
    private string filterStatus = "";

    private CancellationTokenSource? _debounceCts;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private UserAdminFilter BuildFilter()
    {
        bool? approved = filterStatus switch
        {
            "approved" => true,
            "pending" => false,
            _ => null
        };
        return new UserAdminFilter(
            Email: string.IsNullOrWhiteSpace(filterEmail) ? null : filterEmail.Trim(),
            IsApproved: approved);
    }

    private async Task LoadAsync()
    {
        error = null;
        try
        {
            result = await UserAdmin.ListAsync(
                BuildFilter(), page, UserAdmin.PageSize, CancellationToken.None);

            // If a deletion emptied the last page, step back one.
            if (result.TotalCount > 0 && result.Items.Count == 0 && page > 1)
            {
                page--;
                result = await UserAdmin.ListAsync(
                    BuildFilter(), page, UserAdmin.PageSize, CancellationToken.None);
            }
        }
        catch (Exception ex)
        {
            error = "Failed to load users. Please try again.";
            Logger.LogError(ex, "Failed to load user list");
        }
    }

    private async Task OnFilterChanged()
    {
        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;
        try
        {
            await Task.Delay(300, token);
            page = 1;
            await LoadAsync();
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task ClearFilters()
    {
        filterEmail = "";
        filterStatus = "";
        page = 1;
        await LoadAsync();
    }

    private async Task PrevPage() { page--; await LoadAsync(); }
    private async Task NextPage() { page++; await LoadAsync(); }

    // ── Per-row actions: mutate, then refresh ONLY that row ──────────────────
    // We avoid reloading the whole page on every click (the old behaviour),
    // which kept the render tree small and the circuit responsive at scale.

    private async Task ApproveAsync(string userId)
    {
        success = null; error = null; busyId = userId;
        try
        {
            await UserAdmin.ApproveAsync(userId, CancellationToken.None);
            await RefreshRowAsync(userId);
            success = "User approved.";
        }
        catch (Exception ex)
        {
            error = "Approve failed.";
            Logger.LogError(ex, "Approve failed for {UserId}", userId);
        }
        finally { busyId = null; }
    }

    private async Task RevokeAsync(string userId)
    {
        success = null; error = null; busyId = userId;
        try
        {
            await UserAdmin.RevokeAsync(userId, CancellationToken.None);
            await RefreshRowAsync(userId);
            success = "Approval revoked.";
        }
        catch (Exception ex)
        {
            error = "Revoke failed.";
            Logger.LogError(ex, "Revoke failed for {UserId}", userId);
        }
        finally { busyId = null; }
    }

    private async Task PromoteAsync(string userId)
    {
        success = null; error = null; busyId = userId;
        try
        {
            await UserAdmin.PromoteToAdminAsync(userId, CancellationToken.None);
            await RefreshRowAsync(userId);
            success = "User promoted to Admin.";
        }
        catch (Exception ex)
        {
            error = "Promote failed.";
            Logger.LogError(ex, "Promote failed for {UserId}", userId);
        }
        finally { busyId = null; }
    }

    private async Task DeleteAsync(string userId)
    {
        success = null; error = null; busyId = userId;
        try
        {
            await UserAdmin.DeleteAsync(userId, CancellationToken.None);
            // A delete changes totals/paging, so a full (but still paged)
            // reload is correct here.
            await LoadAsync();
            success = "User deleted.";
        }
        catch (Exception ex)
        {
            error = "Delete failed.";
            Logger.LogError(ex, "Delete failed for {UserId}", userId);
        }
        finally { busyId = null; }
    }

    /// <summary>
    /// Replace a single row in the current page with its fresh state, without
    /// re-querying or re-rendering the entire list. If the row no longer
    /// matches the active filter, drop it from the view.
    /// </summary>
    private async Task RefreshRowAsync(string userId)
    {
        if (result is null) return;

        var idx = result.Items.FindIndex(r => r.Id == userId);
        if (idx < 0) return;

        var fresh = await UserAdmin.GetRowAsync(userId, CancellationToken.None);
        if (fresh is null)
        {
            result.Items.RemoveAt(idx);
            return;
        }

        // Honour the status filter: e.g. after approving, a "pending"-filtered
        // view should no longer show the row.
        var stillMatches = filterStatus switch
        {
            "approved" => fresh.IsApproved,
            "pending" => !fresh.IsApproved,
            _ => true
        };

        if (stillMatches)
            result.Items[idx] = fresh;
        else
            result.Items.RemoveAt(idx);
    }

    public void Dispose()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
    }
}
