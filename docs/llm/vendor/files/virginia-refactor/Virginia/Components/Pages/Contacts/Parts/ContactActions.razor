@* The form submit is triggered by the parent's EditForm OnValidSubmit;
   this component only needs to render the buttons with type="submit"
   for save and type="button" for everything else. *@

<div class="actions" role="group" aria-label="Form actions">
    <button type="submit"
            class="btn btn-primary"
            disabled="@Saving"
            data-testid="save-contact">
        @(Saving ? "Saving..." : "Save")
    </button>

    @if (!IsNew)
    {
        @if (ConfirmingDelete)
        {
            <span class="confirm-delete"
                  role="group"
                  aria-label="Confirm deletion">
                <span id="confirm-delete-prompt">Are you sure?</span>
                <button type="button"
                        class="btn btn-danger"
                        disabled="@Saving"
                        aria-describedby="confirm-delete-prompt"
                        data-testid="confirm-delete"
                        @ref="_confirmButtonRef"
                        @onclick="OnConfirmDelete">
                    Yes, delete
                </button>
                <button type="button"
                        class="btn btn-secondary"
                        disabled="@Saving"
                        data-testid="cancel-delete"
                        @onclick="OnCancelDeleteConfirm">
                    Cancel
                </button>
            </span>
        }
        else
        {
            <button type="button"
                    class="btn btn-danger"
                    disabled="@Saving"
                    data-testid="delete-contact"
                    @onclick="OnStartDeleteConfirm">
                Delete
            </button>
        }
    }

    <button type="button"
            class="btn btn-secondary"
            data-testid="cancel-contact"
            @onclick="OnCancelClicked">
        Cancel
    </button>
</div>

@code {
    [Parameter] public bool IsNew { get; set; }
    [Parameter] public bool Saving { get; set; }
    [Parameter] public bool ConfirmingDelete { get; set; }
    [Parameter] public EventCallback OnStartDelete { get; set; }
    [Parameter] public EventCallback OnCancelDelete { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private ElementReference _confirmButtonRef;
    private bool _shouldFocusConfirm;
    private bool _wasConfirming;

    protected override void OnParametersSet()
    {
        // Focus the confirm button only on the transition into confirming state,
        // not on every re-render while already confirming.
        if (ConfirmingDelete && !_wasConfirming)
        {
            _shouldFocusConfirm = true;
        }
        _wasConfirming = ConfirmingDelete;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldFocusConfirm && ConfirmingDelete)
        {
            _shouldFocusConfirm = false;
            try
            {
                await _confirmButtonRef.FocusAsync();
            }
            catch
            {
                // Element not present (race with re-render) — ignore.
            }
        }
    }

    private Task OnStartDeleteConfirm() => OnStartDelete.InvokeAsync();
    private Task OnCancelDeleteConfirm() => OnCancelDelete.InvokeAsync();
    private Task OnConfirmDelete() => OnDelete.InvokeAsync();
    private Task OnCancelClicked() => OnCancel.InvokeAsync();
}
