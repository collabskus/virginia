@using Virginia.Data

<section class="card" aria-labelledby="addresses-heading">
    <div class="card-head">
        <h2 id="addresses-heading">Addresses</h2>
        <button type="button"
                class="btn btn-add"
                data-testid="add-address"
                @onclick="AddAddress">
            + Add address
        </button>
    </div>

    @if (Items.Count == 0)
    {
        <p class="hint" data-testid="addresses-empty">No mailing addresses yet.</p>
    }
    else
    {
        <ul class="child-list" role="list" data-testid="addresses-list">
            @foreach (var item in Items)
            {
                var hash = item.GetHashCode().ToString("x");
                var labelId = $"addr-label-{hash}";
                var streetId = $"addr-street-{hash}";
                var cityId = $"addr-city-{hash}";
                var stateId = $"addr-state-{hash}";
                var postalId = $"addr-postal-{hash}";
                var countryId = $"addr-country-{hash}";

                <li class="child-item" @key="item" data-testid="address-item">
                    <div class="row">
                        <div class="group group-sm">
                            <label for="@labelId">Label</label>
                            <InputText id="@labelId"
                                       @bind-Value="item.Label"
                                       data-testid="address-label" />
                        </div>
                        <button type="button"
                                class="btn-x"
                                aria-label="Remove address"
                                data-testid="remove-address"
                                @onclick="() => RemoveAddress(item)">
                            ✕
                        </button>
                    </div>
                    <div class="row">
                        <div class="group">
                            <label for="@streetId">Street <span aria-hidden="true">*</span></label>
                            <InputText id="@streetId"
                                       @bind-Value="item.Street"
                                       aria-required="true"
                                       aria-describedby="@($"{streetId}-val")"
                                       data-testid="address-street" />
                            <div id="@($"{streetId}-val")" class="field-validation">
                                <ValidationMessage For="() => item.Street" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="group">
                            <label for="@cityId">City <span aria-hidden="true">*</span></label>
                            <InputText id="@cityId"
                                       @bind-Value="item.City"
                                       aria-required="true"
                                       aria-describedby="@($"{cityId}-val")"
                                       data-testid="address-city" />
                            <div id="@($"{cityId}-val")" class="field-validation">
                                <ValidationMessage For="() => item.City" />
                            </div>
                        </div>
                        <div class="group group-sm">
                            <label for="@stateId">State</label>
                            <InputText id="@stateId"
                                       @bind-Value="item.State"
                                       data-testid="address-state" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="group group-sm">
                            <label for="@postalId">Postal Code <span aria-hidden="true">*</span></label>
                            <InputText id="@postalId"
                                       @bind-Value="item.PostalCode"
                                       aria-required="true"
                                       aria-describedby="@($"{postalId}-val")"
                                       data-testid="address-postal" />
                            <div id="@($"{postalId}-val")" class="field-validation">
                                <ValidationMessage For="() => item.PostalCode" />
                            </div>
                        </div>
                        <div class="group group-sm">
                            <label for="@countryId">Country <span aria-hidden="true">*</span></label>
                            <InputText id="@countryId"
                                       @bind-Value="item.Country"
                                       aria-required="true"
                                       aria-describedby="@($"{countryId}-val")"
                                       data-testid="address-country" />
                            <div id="@($"{countryId}-val")" class="field-validation">
                                <ValidationMessage For="() => item.Country" />
                            </div>
                        </div>
                    </div>
                </li>
            }
        </ul>
    }
</section>

@code {
    [Parameter, EditorRequired]
    public List<AddressFormModel> Items { get; set; } = default!;

    private void AddAddress() => Items.Add(new AddressFormModel());
    private void RemoveAddress(AddressFormModel item) => Items.Remove(item);
}
